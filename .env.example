# ─────────────────────────────────────────────────────────────────────────────
# FUENTE DE RESULTADOS
# Por defecto la app usa TheSportsDB (GRATIS, SIN CLAVE) y muestra los
# resultados reales del Mundial. No necesitas configurar NADA para empezar.
# ─────────────────────────────────────────────────────────────────────────────

# (Opcional) Clave de API-Football (https://www.api-football.com/, gratis 100 req/día).
# Si la rellenas, se usa como fuente principal (datos más completos, incl.
# eliminatorias y campeón). Si la dejas vacía, se usa TheSportsDB.
API_FOOTBALL_KEY=

# (Opcional) Pon SPORTSDB_OFF=1 para desactivar TheSportsDB y forzar modo demo.
# SPORTSDB_OFF=
